{
  "name": "linsight-server",
  "version": "0.1.0",
  "private": true,
  "description": "Linsight 后端：Express + TypeScript + better-sqlite3",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --experimental-sqlite src/index.ts",
    "build": "tsc",
    "start": "node --experimental-sqlite dist/index.js",
    "db:init": "tsx --experimental-sqlite src/db/init.ts",
    "db:seed": "tsx --experimental-sqlite src/db/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
